<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="800.0" prefWidth="800.0" style="-fx-background-color: #6482AD;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.slimefighter.slimefighter.GameController">
   <children>
      <ImageView fitHeight="600.0" fitWidth="903.0" layoutX="100.0" pickOnBounds="true" preserveRatio="true">
